generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  DIRECTOR
  SUPERVISOR
  TRAINEE
}

enum TrainingRoute {
  INDIVIDUAL_MODULES
  FULL_22
}

model User {
  id            String        @id @default(cuid())
  email         String        @unique
  name          String?
  role          Role          @default(TRAINEE)
  trainingRoute TrainingRoute @default(FULL_22)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  results        QuizResult[]
  progress       ModuleProgress[]
  moduleAttempts ModuleAttempt[]
}

model Module {
  id        Int    @id
  name      String
  passMark  Int    @default(15)
  questions Json

  results        QuizResult[]
  progress       ModuleProgress[]
  moduleAttempts ModuleAttempt[]
}

model ModuleAttempt {
  id            String   @id @default(cuid())
  userId        String
  moduleId      Int
  score         Int
  passed        Boolean
  answers       Json
  errors        Json
  timeSpent     Int
  attemptNumber Int      @default(1)
  startedAt     DateTime @default(now())
  completedAt   DateTime

  user   User   @relation(fields: [userId], references: [id])
  module Module @relation(fields: [moduleId], references: [id])
}

model QuizResult {
  id        String   @id @default(cuid())
  score     Int
  passed    Boolean  @default(false)
  moduleId  Int
  userId    String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])
  module Module @relation(fields: [moduleId], references: [id])
}

model ModuleProgress {
  id       String    @id @default(cuid())
  userId   String
  moduleId Int
  status   String    @default("locked")
  score    Int?
  attempts Int       @default(0)
  passedAt DateTime?

  user   User   @relation(fields: [userId], references: [id])
  module Module @relation(fields: [moduleId], references: [id])

  @@unique([userId, moduleId])
}

model LoginCode {
  id        String   @id @default(cuid())
  email     String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}
